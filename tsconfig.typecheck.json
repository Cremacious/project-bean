{
  // Type-check config used by `npm run typecheck` (and CI). It extends the base
  // tsconfig but excludes test files: several *.test.ts intentionally pass partial
  // env objects and fixtures that do not satisfy the strict source types, and those
  // tests are already exercised for real by `npm run test`. This keeps the
  // type-check focused on shippable app/lib code. (Tracked follow-up: tighten the
  // test files so they can be type-checked too.)
  "extends": "./tsconfig.json",
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx"]
}
