# .env.example
#
# Single source of truth for the app's environment variables. Copy to .env.local
# for local dev, and mirror the same keys into the Vercel project (see
# docs/DEPLOYMENT.md). Only DATABASE_URL, BETTER_AUTH_SECRET, BETTER_AUTH_URL and
# NEXT_PUBLIC_APP_URL are required; every other integration below no-ops cleanly
# when its key is absent. On Vercel, BETTER_AUTH_URL and NEXT_PUBLIC_APP_URL MUST
# differ per environment: the production domain for Production, the deployment/
# branch URL for Preview. Any OAuth redirect URL must point at that same origin.

# Neon Postgres. On Vercel use the POOLED connection string (host contains
# "-pooler") so serverless functions do not exhaust direct connections.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# BetterAuth. Generate the secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"

# Public base URL used by the browser auth client.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional social providers (leave unset in dev; a provider only activates when
# its credentials below are present).
#
# Google (issue #15): create an OAuth 2.0 Client ID of type "Web application"
# in Google Cloud, and add this Authorized redirect URI:
#   local: http://localhost:3000/api/auth/callback/google
#   prod:  https://YOUR_DOMAIN/api/auth/callback/google
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
#
# Apple (issue #16): Apple's OAuth client secret is a signed JWT the app
# generates from your .p8 key (do NOT paste a static secret). Create a Services
# ID + a Sign in with Apple key in the Apple Developer portal, then set the four
# values below. Apple return URLs must be HTTPS on a real domain (Apple rejects
# http:// and localhost), so register:
#   prod/tunnel: https://YOUR_DOMAIN/api/auth/callback/apple
# APPLE_CLIENT_ID is the Services ID (e.g. "app.bedtimequests.web").
# APPLE_PRIVATE_KEY is the whole AuthKey_XXXXXXXXXX.p8 file, kept on one line
# with the newlines escaped as \n.
# APPLE_CLIENT_ID=""
# APPLE_TEAM_ID=""
# APPLE_KEY_ID=""
# APPLE_PRIVATE_KEY=""
# Alternative to the four values above: a pre-generated client-secret JWT (e.g.
# built in a deploy pipeline). If set, it is used as-is and the .p8 signing is
# skipped. Leave unset to let the app sign the secret from the .p8 key above.
# APPLE_CLIENT_SECRET=""

# Comma-separated emails allowed into /admin
ADMIN_EMAILS=

# RevenueCat (issue #33): subscription entitlements. The web app does NOT sell
# subscriptions on the web today; RevenueCat becomes the source of truth when the
# native apps ship (milestone M6). Leave this unset in dev: without it the
# entitlement helper simply reports "not subscribed" and the webhook returns 503,
# so the app still runs. COPPA (docs/COMPLIANCE-COPPA.md section 6c): the
# RevenueCat app_user_id is the PARENT account id only, never a child name or id.
#
# Shared secret for the webhook Authorization header. In the RevenueCat
# dashboard: Project settings > Integrations > Webhooks. Set the webhook URL to
#   https://YOUR_DOMAIN/api/revenuecat/webhook
# and set an "Authorization header value"; paste that exact value here. The
# webhook rejects any request whose Authorization header does not match.
# REVENUECAT_WEBHOOK_AUTH_TOKEN=""
#
# Plans and trial (issue #35). The web plan picker is display only; the purchase
# runs in the native app (M6, #55). There are NO new env secrets to set for #35:
# a native purchase becomes web entitlement through the webhook token above.
# What you DO configure, outside of env, so a purchase maps to the "premium"
# entitlement the app reads:
#   In App Store Connect and Google Play, create these subscription products
#   (prices are the launch prices; a 7 day free trial / intro offer on each):
#     bedtimequests_premium_monthly  ->  $4.99 per month
#     bedtimequests_premium_yearly   ->  $29.99 per year
#   In RevenueCat, attach both products to a single entitlement named "premium".
#   These product identifiers are mirrored in lib/plans.ts (PRODUCT_ID_MONTHLY /
#   PRODUCT_ID_YEARLY); keep the two in sync.

# Kid-safe advertising (issue #37). Ads show to FREE-tier parents ONLY; subscribers
# and trial users never see an ad and never load any ad code (gated on the issue #33
# entitlement). Every ad path is NON-personalized / child-directed: contextual only,
# no behavioral tracking, no persistent identifiers, no child data shared (see
# docs/COMPLIANCE-COPPA.md section 6a).
#
# GLOBAL KILL SWITCH. Ads are OFF unless this is exactly "true" (or "1"). Absent =
# off, so local dev and CI run with no ads and no ad config. Set it to "false" (or
# remove it) to instantly disable every ad everywhere if a store or legal review
# flags them.
# ADS_ENABLED="false"
#
# Which ad path renders. "house" (default) serves our OWN promos with no third party
# and no data leaving the app: the safe default that ships today. Switch to a paid
# network only AFTER its unit id below is set AND vendor / LAWYER sign-off confirms a
# contextual, child-directed, COPPA-compliant configuration (docs/COMPLIANCE-COPPA.md
# section 6a and section 9 question 3). Do NOT use plain AdSense: its policy restricts
# made-for-kids sites.
#   house         -> self-promotion, zero third-party data (safe default)
#   superawesome  -> kid-focused contextual network (needs the placement id below)
#   google-gam    -> Google Ad Manager, child-directed (tfcd) + non-personalized
# NEXT_PUBLIC_ADS_NETWORK="house"
#
# Third-party unit ids. If the selected network's id is missing or blank, ads stay
# OFF (graceful): the app runs cleanly with these unset. House ads need neither.
# NEXT_PUBLIC_SUPERAWESOME_PLACEMENT_ID=""
# NEXT_PUBLIC_GOOGLE_AD_UNIT_ID=""

# Product analytics (issue #38), configured for a CHILD-DIRECTED app. Analytics
# sends NO personal data: only a fixed, non-personal event taxonomy (story slug,
# age band, plan type, ending category) fires through the single track() helper
# in lib/analytics.ts, which strips any personal-looking field as a safety net.
# The child's name, the parent's email, and any user id NEVER reach analytics.
# When GA loads it runs in restricted mode: Google Signals off, ad
# personalization off, IP anonymized, all advertising storage denied (see
# docs/COMPLIANCE-COPPA.md section 6b).
#
# GA4 measurement id (G-XXXXXXXXXX). This is the ON switch: with it UNSET,
# analytics is fully OFF, so local dev and CI load no analytics code and make no
# analytics network calls. COPPA caution (docs/COMPLIANCE-COPPA.md section 9 Q2):
# confirm Google's own terms permit your child-directed configuration before
# enabling in production, or switch to a cookieless analytics provider.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=""
#
# GLOBAL KILL SWITCH. Defaults ON when a measurement id is present. Set to
# "false" (or "0") to instantly disable ALL analytics everywhere while keeping the
# id in place, e.g. if a store or legal review flags it.
# NEXT_PUBLIC_ANALYTICS_ENABLED="true"
#
# Consent gating (coordinates with the consent banner, M5 #50). Leave "false"
# (default) to load analytics immediately in the strictly non-personal,
# child-directed config above. Set "true" where a region requires opt-in consent;
# analytics then waits until the banner grants it.
# NEXT_PUBLIC_ANALYTICS_REQUIRE_CONSENT="false"

# Crash and error reporting (issue #39), via Sentry, configured privacy-safely
# for a CHILD-DIRECTED app. Reporting sends NO personal data: sendDefaultPii is
# OFF and every event passes through a beforeSend scrubber (lib/reporting.ts) that
# strips the child name, the parent email, request bodies, cookies, query strings,
# and any user/session id, keeping only a non-identifying opaque id for grouping.
# There is NO Session Replay and NO performance tracing (replay would record the
# personalized story text on screen). See docs/COMPLIANCE-COPPA.md sections 2, 6, 7.
#
# Sentry DSN. This is the ON switch: with it UNSET, reporting is fully OFF, so
# local dev and CI initialize nothing and make no reporting network calls. The DSN
# is not a secret (it ships in the client bundle), so it uses the NEXT_PUBLIC_
# prefix and is read by the browser, server, and edge runtimes alike. Get it from
# your Sentry project: Settings > Client Keys (DSN).
# NEXT_PUBLIC_SENTRY_DSN=""
#
# GLOBAL KILL SWITCH. Defaults ON when a DSN is present. Set to "false" (or "0")
# to instantly disable ALL reporting everywhere while keeping the DSN in place.
# NEXT_PUBLIC_SENTRY_ENABLED="true"
#
# Environment tag so prod errors are told apart from dev. Defaults to NODE_ENV
# (development / production); override only if you want a distinct tag (e.g.
# "staging" on a preview deploy).
# NEXT_PUBLIC_SENTRY_ENVIRONMENT="production"
#
# Optional release/version for grouping errors by deploy. Leave unset to skip it
# (source-map upload and release wiring are intentionally not required here).
# NEXT_PUBLIC_SENTRY_RELEASE=""

# Transactional email (Resend) for password reset. When either is unset in dev,
# emails are logged to the server console (link included) instead of sent.
# EMAIL_FROM must be a verified sender, e.g. "Bedtime Quests <hello@yourdomain.com>".
RESEND_API_KEY=
EMAIL_FROM=
