# .env.example
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secret used to sign the session cookie. Generate with: openssl rand -base64 32
SESSION_SECRET="generate-with: openssl rand -base64 32"

# The single login credential for the site. The username should match the
# `username` of the reader whose stories should appear after signing in.
AUTH_USERNAME="milo"
AUTH_PASSWORD="storytime"
