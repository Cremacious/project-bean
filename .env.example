# .env.example
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# BetterAuth. Generate the secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"

# Public base URL used by the browser auth client.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional social providers (leave unset in dev; a provider only activates when
# its credentials below are present).
#
# Google (issue #15): create an OAuth 2.0 Client ID of type "Web application"
# in Google Cloud, and add this Authorized redirect URI:
#   local: http://localhost:3000/api/auth/callback/google
#   prod:  https://YOUR_DOMAIN/api/auth/callback/google
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
#
# Apple (issue #16): Apple's OAuth client secret is a signed JWT the app
# generates from your .p8 key (do NOT paste a static secret). Create a Services
# ID + a Sign in with Apple key in the Apple Developer portal, then set the four
# values below. Apple return URLs must be HTTPS on a real domain (Apple rejects
# http:// and localhost), so register:
#   prod/tunnel: https://YOUR_DOMAIN/api/auth/callback/apple
# APPLE_CLIENT_ID is the Services ID (e.g. "app.bedtimequests.web").
# APPLE_PRIVATE_KEY is the whole AuthKey_XXXXXXXXXX.p8 file, kept on one line
# with the newlines escaped as \n.
# APPLE_CLIENT_ID=""
# APPLE_TEAM_ID=""
# APPLE_KEY_ID=""
# APPLE_PRIVATE_KEY=""

# Comma-separated emails allowed into /admin
ADMIN_EMAILS=

# RevenueCat (issue #33): subscription entitlements. The web app does NOT sell
# subscriptions on the web today; RevenueCat becomes the source of truth when the
# native apps ship (milestone M6). Leave this unset in dev: without it the
# entitlement helper simply reports "not subscribed" and the webhook returns 503,
# so the app still runs. COPPA (docs/COMPLIANCE-COPPA.md section 6c): the
# RevenueCat app_user_id is the PARENT account id only, never a child name or id.
#
# Shared secret for the webhook Authorization header. In the RevenueCat
# dashboard: Project settings > Integrations > Webhooks. Set the webhook URL to
#   https://YOUR_DOMAIN/api/revenuecat/webhook
# and set an "Authorization header value"; paste that exact value here. The
# webhook rejects any request whose Authorization header does not match.
# REVENUECAT_WEBHOOK_AUTH_TOKEN=""
#
# Plans and trial (issue #35). The web plan picker is display only; the purchase
# runs in the native app (M6, #55). There are NO new env secrets to set for #35:
# a native purchase becomes web entitlement through the webhook token above.
# What you DO configure, outside of env, so a purchase maps to the "premium"
# entitlement the app reads:
#   In App Store Connect and Google Play, create these subscription products
#   (prices are the launch prices; a 7 day free trial / intro offer on each):
#     bedtimequests_premium_monthly  ->  $4.99 per month
#     bedtimequests_premium_yearly   ->  $29.99 per year
#   In RevenueCat, attach both products to a single entitlement named "premium".
#   These product identifiers are mirrored in lib/plans.ts (PRODUCT_ID_MONTHLY /
#   PRODUCT_ID_YEARLY); keep the two in sync.

# Transactional email (Resend) for password reset. When either is unset in dev,
# emails are logged to the server console (link included) instead of sent.
# EMAIL_FROM must be a verified sender, e.g. "Bedtime Quests <hello@yourdomain.com>".
RESEND_API_KEY=
EMAIL_FROM=
